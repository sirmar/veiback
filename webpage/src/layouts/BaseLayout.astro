---
import '../styles/globals.css';
import '../styles/animations.css';
import Nav from '../components/Nav.astro';
import HeroBackground from '../components/HeroBackground.astro';
import type { Locale } from '../lib/types';

interface Props {
  locale: Locale;
  title?: string;
}

const { locale, title = 'Veibäck Effektiv Utveckling AB' } = Astro.props;
const otherLocale = locale === 'sv' ? 'en' : 'sv';
const otherPath = `/${otherLocale}/`;
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Veibäck Effektiv Utveckling AB — Marcus Veibäck" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>
  <HeroBackground />
  <Nav locale={locale} otherPath={otherPath} />
  <slot />
  <script>
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.15 }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // Hero stagger
    document.querySelectorAll('.hero .fade-in').forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), i * 400);
    });
  </script>
</body>
</html>
