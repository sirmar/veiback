---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import About from '../../components/About.astro';
import Experience from '../../components/Experience.astro';
import Clients from '../../components/Clients.astro';
import Contact from '../../components/Contact.astro';
import { loadContent, loadResume } from '../../lib/dataLoader';
import type { Locale } from '../../lib/types';

export async function getStaticPaths() {
  return [{ params: { lang: 'sv' } }, { params: { lang: 'en' } }];
}

const locale = Astro.params.lang as Locale;
const content = loadContent(locale);
const resume = loadResume();
---
<BaseLayout locale={locale}>
  <Hero content={content} />
  <Services content={content} locale={locale} />
  <About content={content} locale={locale} />
  <Experience resume={resume} locale={locale} />
  <Clients content={content} locale={locale} />
  <Contact resume={resume} locale={locale} />
</BaseLayout>
